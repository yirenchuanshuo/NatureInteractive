#include "/Engine/Private/Common.ush"
Texture2D SnowOffsetInput;
RWTexture2D<float4> SnowOffsetOutput;
int2 Offset;

[numthreads(SIZE_X,SIZE_Y,SIZE_Z)]
void SnowOffsetCS(uint3 ThreadId : SV_DispatchThreadID)
{
	int2 Pos = ThreadId.xy;
	int2 FinalPos = Pos + Offset.xy;
	
	SnowOffsetOutput[ThreadId.xy] = SnowOffsetInput[FinalPos];
}